{
  "compilerOptions": {
    "jsx": "react-jsx",
    "strict": true,
    "target": "ES2020",
    "lib": ["DOM", "ES2020"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "rootDir": "./src",
    "outDir": "./dist",
    "allowJs": false,
    "noEmit": true,
    "skipLibCheck": true
  },
  "include": ["src"]
}
